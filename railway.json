{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd sns-daemon && cargo build --release --bin sns-daemon",
    "watchPatterns": ["sns-daemon/**"]
  },
  "deploy": {
    "startCommand": "[ -f ./target/release/sns-daemon ] && ./target/release/sns-daemon || ./sns-daemon/target/release/sns-daemon",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
