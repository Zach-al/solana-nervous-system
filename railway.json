{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd sns-daemon && cargo build --release --bin sns-daemon"
  },
  "deploy": {
    "startCommand": "./sns-daemon/target/release/sns-daemon",
    "restartPolicyType": "ON_FAILURE", 
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 180
  }
}
