# Node identity
NODE_NAME=my-solnet-node

# Ports
HTTP_PORT=9000
P2P_PORT=9001

# Solana network
SOLANA_RPC_URL=https://api.devnet.solana.com

# Logging (trace|debug|info|warn|error)
LOG_LEVEL=info

# Security — generate with: solana-keygen new --no-bip39-passphrase
NODE_SECRET_KEY=generate-with-solana-keygen

# Rate limiter
MAX_REQUESTS_PER_MIN=100

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECS=30
